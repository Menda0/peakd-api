# If Auth0 client secret or MongoDB password was ever pasted into chat or committed, rotate them in the dashboards.
PORT=3001

# Auth0 (JWT validation for API). Issuer is your tenant URL with https, no trailing path.
AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
# API Identifier from Auth0 Dashboard → APIs → your API
AUTH0_AUDIENCE=https://peakd-api
# RBAC: assign Auth0 roles (e.g. partner, admin) and enable "Add Roles in the Access Token" for this API.
# Admin routes (/admin/*) require the admin role (case-insensitive) in the access token JWT.
# Optional fallback (same as peakd-frontend): Management API M2M with read:user_roles
# AUTH0_MANAGEMENT_CLIENT_ID=
# AUTH0_MANAGEMENT_CLIENT_SECRET=
# AUTH0_MANAGEMENT_DOMAIN=your-tenant.us.auth0.com

# MongoDB (include database name in path, e.g. ...mongodb.net/peakd?retryWrites=true&w=majority)
MONGODB_URI=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Original video uploads and raw session ZIP exports (configure ~30d lifecycle in S3)
S3_RAW_BUCKET=peakd-raw
# Days shown on “download raw” and aligned with raw-bucket lifecycle (default 30)
RAW_EXPORT_RETENTION_DAYS=30
# Optional: Cloudflare R2, MinIO, LocalStack
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# Optional public URL prefix for objects (e.g. CloudFront). If unset, partner avatar URLs use presigned GETs.
# S3_PUBLIC_BASE_URL=https://cdn.example.com

# Partner profile avatars (presigned PUT / GET; keys: partners/avatars/{encodedAuth0Sub}/...)
PARTNER_AVATAR_GET_URL_EXPIRY_SECONDS=604800
PARTNER_AVATAR_PUT_URL_EXPIRY_SECONDS=600

WATERMARK_IMAGE_PATH=/absolute/path/to/logo.png
# Social MP4 outro logo (defaults to peakd-api/assets/social-outro-logo.png)
# SOCIAL_OUTRO_LOGO_PATH=/absolute/path/to/social-outro-logo.png
# SOCIAL_OUTRO_DURATION_SEC=3
# SOCIAL_H264_CRF=23
# SOCIAL_SMART_CROP_ENABLED=true
# SOCIAL_TRACK_SAMPLE_FPS=4
# SOCIAL_TRACK_MAX_SAMPLE_FRAMES=120
# SOCIAL_TRACK_SMOOTHING=0.25
# SOCIAL_TRACK_MIN_CONFIDENCE=0.45
# SOCIAL_TRACK_MAX_PAN_PX_PER_SEC=900
# SOCIAL_TRACK_FALLBACK_CENTER_Y=0.58
# SOCIAL_DETECTOR_MODEL_PATH=/absolute/path/to/yolov8n.onnx

# If the API process has no ffmpeg on PATH (common when launched from the IDE), set full paths:
# FFMPEG_PATH=/opt/homebrew/bin/ffmpeg
# FFPROBE_PATH=/opt/homebrew/bin/ffprobe
MAX_UPLOAD_MB=500
# VP9: higher CRF = smaller file, lower quality (typical web ~34–42). Default tuned for stronger compression.
VP9_CRF=37
# 0 = slowest encode, best bits-per-quality (default). 3–5 = faster, slightly larger files.
VP9_CPU_USED=0
# Opus bitrate when input has audio (smaller = more compression)
OPUS_AUDIO_BITRATE_K=64
PRESIGNED_URL_EXPIRY_SECONDS=3600
SNAPSHOT_INTERIOR_START_RATIO=0.08
SNAPSHOT_INTERIOR_END_RATIO=0.92
# Snapshot count scales from min (short clips) to max (long clips), linear between scale durations
SNAPSHOT_MIN_FRAMES=5
SNAPSHOT_MAX_FRAMES=10
SNAPSHOT_SCALE_SHORT_SEC=20
SNAPSHOT_SCALE_LONG_SEC=120
ALLOWED_VIDEO_MIME_TYPES=video/mp4,video/quicktime,video/webm,video/x-msvideo,video/x-matroska

# Comma-separated browser origins for CORS (e.g. Next dev). If unset, all origins are allowed.
# CORS_ORIGIN=http://localhost:3000

# Platform commission charged on top of every partner-defined wave price at
# checkout. Paid by the buyer, kept by the platform. Default 20 (%).
PLATFORM_COMMISSION_PERCENT=20
# Stripe processing fees used to gross-up checkout totals so partners receive
# their configured base price and the platform keeps the full commission.
# Defaults: 2.9 (%) + 30 minor units (e.g. $0.30).
STRIPE_PROCESSING_FEE_PERCENT=2.9
STRIPE_PROCESSING_FEE_FIXED_MINOR=30
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: separate signing secret for Stripe Connect account events.
# If unset, STRIPE_WEBHOOK_SECRET is used for both.
STRIPE_CONNECT_WEBHOOK_SECRET=
# Shared with peakd-frontend for BFF → API after Stripe signature verification (openssl rand -hex 32)
BILLING_WEBHOOK_INTERNAL_SECRET=
# Frontend origin for Stripe Checkout return URLs (no trailing slash)
APP_BASE_URL=http://localhost:3000

# Partner bank withdrawals via Stripe Connect.
# Minimum withdrawal per ISO 4217 currency, in integer minor units (cents etc.).
# JSON object keyed by lowercase currency code. Currencies not listed fall back
# to 100 minor units.
PARTNER_MIN_WITHDRAWAL_BY_CURRENCY={"eur":1000,"usd":1000,"gbp":1000,"aud":1500,"cad":1500,"brl":5000,"jpy":1000}
# Path appended to APP_BASE_URL for Connect onboarding return/refresh URLs.
PARTNER_PAYOUT_RETURN_PATH=/partner/income
